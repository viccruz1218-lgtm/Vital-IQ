# Supabase — from your project's Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic — Claude API key
ANTHROPIC_API_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_MONTHLY=
STRIPE_PRICE_ID_YEARLY=

# Base URL used for Stripe redirect/webhook callbacks
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Shared secret Vercel Cron sends as `Authorization: Bearer $CRON_SECRET`
# to authenticate against /api/cron/nightly
CRON_SECRET=

# Comma-separated emails allowed into /admin (founder metrics + user ops
# dashboards). No DB-backed admin role exists — this is the whole gate.
ADMIN_EMAILS=
